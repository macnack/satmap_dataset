# Load optional local overrides from .env (if present).
dotenv_if_exists .env

# Activate project virtualenv (prefer .venv, fallback to venv).
if [[ -f .venv/bin/activate ]]; then
  source .venv/bin/activate
elif [[ -f venv/bin/activate ]]; then
  source venv/bin/activate
fi

# Helpful defaults for local development.
export PROJECT_ROOT="$PWD"
export PYTHONPATH="$PWD/src${PYTHONPATH:+:$PYTHONPATH}"
export PYTHONUNBUFFERED=1
export PIP_DISABLE_PIP_VERSION_CHECK=1

# Common project paths for commands/scripts.
export SATMAP_BASE_JSON="configs/run/base.json"
export SATMAP_LOCATIONS_DIR="configs/run/locations"
